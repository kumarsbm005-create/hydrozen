{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/env.js", "dest": "server.js" },
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|webp|svg|ico|woff|woff2))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}
